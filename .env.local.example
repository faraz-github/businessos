# ─── Supabase ───────────────────────────────────────────────
# Database only — Supabase Auth is NOT used in this project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to client or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── JWT ────────────────────────────────────────────────────
# Minimum 64 random characters. Used to sign session tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-secret-here

# ─── SuperAdmin Seed ────────────────────────────────────────
# Used by POST /api/auth/seed to create or reset the superadmin account.
# After seeding, you can change these values — they are only read during seeding.
# Password must be at least 8 characters.
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=changeme123
SUPERADMIN_NAME=Super Admin

# ─── Seed Endpoint Secret ───────────────────────────────────
# Required to call POST/GET /api/auth/seed.
# Without this set, the seed endpoint returns 503 (disabled).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SEED_SECRET=your-64-char-random-secret-here
