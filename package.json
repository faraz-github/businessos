    "@react-pdf/renderer": "^4.3.0",
    "framer-motion": "^11.18.0",
    "recharts": "^2.15.0",
    "react-hook-form": "^7.54.0",
    "@hookform/resolvers": "^3.9.0",
    "zod": "^3.24.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.468.0",
    "clsx": "^2.1.0",
    "nanoid": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.3",
